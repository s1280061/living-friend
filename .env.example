# ─────────────────────────────────────────────
#  Supabase
# ─────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Server-only. Never expose to the browser. Used by API routes & cron.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─────────────────────────────────────────────
#  Groq Cloud — OpenAI-compatible Chat Completions API
#  Get a key at https://console.groq.com/keys (starts with "gsk_")
# ─────────────────────────────────────────────
GROQ_API_KEY=gsk_...
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=llama-3.3-70b-versatile

# ─────────────────────────────────────────────
#  News provider
#  "rss"     = Yahoo!ニュース RSS (default) — NO API KEY, works in production, 日本語
#  "newsapi" = NewsAPI.org (needs key below; free tier is dev-only)
# ─────────────────────────────────────────────
NEWS_PROVIDER=rss
NEWS_API_KEY=
NEWS_API_BASE_URL=https://newsapi.org/v2

# ─────────────────────────────────────────────
#  Cron protection — Vercel Cron sends this as a Bearer token.
#  Generate any long random string.
# ─────────────────────────────────────────────
CRON_SECRET=replace-with-a-long-random-string

# Which friend the single-user MVP defaults to (slug from friends table).
DEFAULT_FRIEND_SLUG=haru
